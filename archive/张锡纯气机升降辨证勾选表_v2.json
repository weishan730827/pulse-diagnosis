  "step5_六经方证映射": {
    "_description": "张锡纯以气机升降视角重释六经——'六经实为十二经，以足赅手'。太阳经热力源自君相二火，胸中大气为枢纽。每条经的症状来自宋本《伤寒论》六经提纲证原文，张锡纯解读来自decision_tree六经气化对应表。",
    "_shared_source": "宋本《伤寒论》六经提纲条文 + 张锡纯《六经总论》气化解读",
    "sections": [
      {
        "id": "ZXC_S5_TAIYANG",
        "label": "八、太阳病（大气不足→卫外失固）",
        "zxc_interpretation": "太阳经热力生于君相二火，以胸中大气为枢纽外通营卫。大气不足→卫外失固→风邪乘虚而入（桂枝汤证）；寒水郁闭→表气不通（麻黄汤证）。",
        "type": "checkbox",
        "items": [
          {"id": "zxc_taiyang_fa_re_wu_feng", "text": "发热恶风", "maps_to": "桂枝汤", "source": "太阳病提纲·第1条"},
          {"id": "zxc_taiyang_han_chu", "text": "汗出", "maps_to": "桂枝汤", "source": "太阳中风·第2条", "zxc_note": "卫外失固，营阴外泄"},
          {"id": "zxc_taiyang_mai_fu_huan", "text": "脉浮缓", "maps_to": "桂枝汤", "source": "太阳中风·第2条", "zxc_note": "大气不足，脉虽浮而缓弱"},
          {"id": "zxc_taiyang_tou_xiang_qiang_tong", "text": "头项强痛", "maps_to": "桂枝汤", "source": "太阳病提纲·第1条"},
          {"id": "zxc_taiyang_e_han_wu_han", "text": "恶寒无汗", "maps_to": "麻黄汤", "source": "太阳伤寒·第3条", "zxc_note": "寒水郁闭，表气不通"},
          {"id": "zxc_taiyang_shen_teng", "text": "身疼腰痛骨节疼痛", "maps_to": "麻黄汤", "source": "太阳伤寒·第35条"},
          {"id": "zxc_taiyang_mai_fu_jin", "text": "脉浮紧", "maps_to": "麻黄汤", "source": "太阳伤寒·第3条", "zxc_note": "寒邪束表，脉道拘急"},
          {"id": "zxc_taiyang_ke_chuan", "text": "喘（表闭肺气不降）", "maps_to": "麻黄汤", "source": "太阳伤寒·第35条"}
        ]
      },
      {
        "id": "ZXC_S5_YANGMING",
        "label": "九、阳明病（胃气不降→郁而化热化燥）",
        "zxc_interpretation": "胃气当降不降，郁而化热。经证白虎汤清降阳明，腑证承气汤通降燥结。",
        "type": "checkbox",
        "items": [
          {"id": "zxc_yangming_shen_re_han_chu", "text": "身大热汗自出", "maps_to": "白虎汤", "source": "阳明病·第182条"},
          {"id": "zxc_yangming_da_ke", "text": "大渴引饮", "maps_to": "白虎汤", "source": "白虎加人参汤证·第26条"},
          {"id": "zxc_yangming_mai_hong_da", "text": "脉洪大/洪滑", "maps_to": "白虎汤", "source": "白虎汤证·第176条", "zxc_note": "胃热蒸腾，气分热盛"},
          {"id": "zxc_yangming_bu_e_han_fan_e_re", "text": "不恶寒反恶热", "maps_to": "白虎汤", "source": "阳明病·第182条"},
          {"id": "zxc_yangming_fu_man_bian_mi", "text": "腹满便秘", "maps_to": "大承气汤", "source": "阳明腑证·第215条"},
          {"id": "zxc_yangming_chao_re_zhan_yu", "text": "潮热谵语", "maps_to": "大承气汤", "source": "阳明腑证·第212条"},
          {"id": "zxc_yangming_mai_chen_shi", "text": "脉沉实/沉滑有力", "maps_to": "大承气汤", "source": "阳明腑证·第240条", "zxc_note": "燥屎内结，脉道沉实"},
          {"id": "zxc_yangming_zheng_men_fan_re", "text": "心中懊憹/烦热", "maps_to": "栀子豉汤", "source": "阳明病·第221条"}
        ]
      },
      {
        "id": "ZXC_S5_SHAOYANG",
        "label": "十、少阳病（枢机不利→气机出入不畅）",
        "zxc_interpretation": "少阳为游部，贯通经气。枢机不利则寒热往来、胸胁苦满。小柴胡汤调畅枢机，和法为治。",
        "type": "checkbox",
        "items": [
          {"id": "zxc_shaoyang_wang_lai_han_re", "text": "往来寒热", "maps_to": "小柴胡汤", "source": "少阳病·第96条"},
          {"id": "zxc_shaoyang_xiong_lei_ku_man", "text": "胸胁苦满", "maps_to": "小柴胡汤", "source": "少阳病·第96条", "zxc_note": "枢机不利，气滞胸胁"},
          {"id": "zxc_shaoyang_kou_ku_yan_gan_mu_xuan", "text": "口苦咽干目眩", "maps_to": "小柴胡汤", "source": "少阳提纲·第263条"},
          {"id": "zxc_shaoyang_mo_mo_bu_yu_yin_shi", "text": "默默不欲饮食", "maps_to": "小柴胡汤", "source": "少阳病·第96条"},
          {"id": "zxc_shaoyang_xin_fan_xi_ou", "text": "心烦喜呕", "maps_to": "小柴胡汤", "source": "少阳病·第96条"},
          {"id": "zxc_shaoyang_mai_xian", "text": "脉弦（少阳主脉）", "maps_to": "小柴胡汤", "source": "少阳病·第266条", "zxc_note": "尺寸俱弦，少阳受病"}
        ]
      },
      {
        "id": "ZXC_S5_TAIYIN",
        "label": "十一、太阴病（中焦气化不足→寒湿内停）",
        "zxc_interpretation": "脾气不升则中焦气化不足，寒湿内停。理中汤温运中焦，与大气下陷之升陷汤不同：大气下陷病在胸中（心肺），太阴病在中焦（脾胃）。",
        "type": "checkbox",
        "items": [
          {"id": "zxc_taiyin_fu_man_tu", "text": "腹满而吐", "maps_to": "理中汤", "source": "太阴提纲·第273条"},
          {"id": "zxc_taiyin_shi_bu_xia", "text": "食不下", "maps_to": "理中汤", "source": "太阴提纲·第273条"},
          {"id": "zxc_taiyin_zi_li", "text": "自利不渴", "maps_to": "理中汤", "source": "太阴病·第277条", "zxc_note": "'自利不渴者属太阴，以其脏有寒故也'"},
          {"id": "zxc_taiyin_shi_fu_zi_tong", "text": "时腹自痛", "maps_to": "理中汤", "source": "太阴提纲·第273条"},
          {"id": "zxc_taiyin_mai_chen_xi_ruo", "text": "脉沉细/沉迟无力", "maps_to": "理中汤", "source": "太阴病·伤寒例", "zxc_note": "尺寸俱沉细，太阴受病"},
          {"id": "zxc_taiyin_she_dan_tai_bai_hua", "text": "舌淡苔白滑", "maps_to": "理中汤"}
        ]
      },
      {
        "id": "ZXC_S5_SHAOYIN",
        "label": "十二、少阴病（肾中水火→寒化/热化两途）",
        "zxc_interpretation": "张锡纯谓少阴寒化→元阳不足→四逆汤回阳；少阴热化→阴虚阳浮→黄连阿胶汤育阴清热。'肾原属水，中藏相火，其水火蒸热之气由膀胱连三焦之脂膜以透达于身之外表。'",
        "type": "checkbox",
        "items": [
          {"id": "zxc_shaoyin_mai_wei_xi", "text": "脉微细", "maps_to": "四逆汤", "source": "少阴提纲·第281条"},
          {"id": "zxc_shaoyin_dan_yu_mei", "text": "但欲寐（精神萎靡）", "maps_to": "四逆汤", "source": "少阴提纲·第281条", "zxc_note": "元阳不足，精神不支"},
          {"id": "zxc_shaoyin_xia_li_qing_gu", "text": "下利清谷", "maps_to": "四逆汤", "source": "少阴病·第317条"},
          {"id": "zxc_shaoyin_si_zhi_jue_leng", "text": "四肢厥冷", "maps_to": "四逆汤", "source": "少阴病·第323条", "zxc_note": "'少阴病脉沉者急温之宜四逆汤'"},
          {"id": "zxc_shaoyin_mai_chen_wei", "text": "脉沉微（尺部尤甚）", "maps_to": "四逆汤", "source": "少阴病·第323条", "zxc_note": "尺寸俱沉，少阴受病"},
          {"id": "zxc_shaoyin_re_xin_fan_bu_de_mian", "text": "心中烦不得卧", "maps_to": "黄连阿胶汤", "source": "少阴热化·第303条", "zxc_note": "阴虚阳浮，心肾不交"},
          {"id": "zxc_shaoyin_re_mai_xi_shu", "text": "脉细数", "maps_to": "黄连阿胶汤", "source": "少阴热化"},
          {"id": "zxc_shaoyin_re_she_hong_shao_tai", "text": "舌红绛少苔", "maps_to": "黄连阿胶汤"}
        ]
      },
      {
        "id": "ZXC_S5_JUEYIN",
        "label": "十三、厥阴病（肝失疏泄→气机逆乱）",
        "zxc_interpretation": "肝主左而宜升。肝脏受邪，气机逆乱→上热下寒、寒热错杂。乌梅丸调肝安冲，辛开苦降。与张锡纯自创之镇肝熄风汤有别：乌梅丸治寒热错杂之厥阴，镇肝熄风汤治肝阳上亢之冲逆。",
        "type": "checkbox",
        "items": [
          {"id": "zxc_jueyin_xiao_ke", "text": "消渴（上热）", "maps_to": "乌梅丸", "source": "厥阴提纲·第326条"},
          {"id": "zxc_jueyin_qi_shang_zhuang_xin", "text": "气上撞心", "maps_to": "乌梅丸", "source": "厥阴提纲·第326条", "zxc_note": "肝气上逆冲心"},
          {"id": "zxc_jueyin_xin_zhong_teng_re", "text": "心中疼热", "maps_to": "乌梅丸", "source": "厥阴提纲·第326条"},
          {"id": "zxc_jueyin_ji_bu_yu_shi", "text": "饥而不欲食", "maps_to": "乌梅丸", "source": "厥阴提纲·第326条", "zxc_note": "脾虚不运"},
          {"id": "zxc_jueyin_shou_zu_jue_leng", "text": "手足厥冷（下寒）", "maps_to": "乌梅丸", "source": "厥阴病·第338条"},
          {"id": "zxc_jueyin_mai_wei_huan", "text": "脉微缓/沉细", "maps_to": "乌梅丸", "source": "厥阴病·伤寒例"}
        ]
      }
    ]
  },

