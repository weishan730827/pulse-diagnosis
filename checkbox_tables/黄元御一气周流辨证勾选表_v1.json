{
  "_name": "黄元御一气周流辨证勾选表",
  "_version": "1.0",
  "_source": "《四圣心源》《长沙药解》",
  "_method": "中气为轴，四维为轮。先问中气→再判四象升降→锁定方药。",
  "_shared_tables": ["知医邦脉诊量化表", "知医邦舌诊量化表"],

  "step1_中气轴心": {
    "description": "中气是黄元御理论的绝对核心。中气不运则百病生。",
    "sections": [
      {
        "id": "HYY_A1_中气",
        "label": "一、中气状态（先做判断）",
        "type": "checkbox",
        "items": [
          {"id": "hyy_zq_pi_xu", "text": "脾虚（食少/便溏/倦怠/舌淡胖/脉缓弱）"},
          {"id": "hyy_zq_wei_ni", "text": "胃逆（呕恶/嗳气/呃逆/胃脘不适）"},
          {"id": "hyy_zq_pixu_ni", "text": "脾虚胃逆（上两项共存）"},
          {"id": "hyy_zq_shi_ji", "text": "食积（脘腹胀满/腐臭嗳气/苔腻）"},
          {"id": "hyy_zq_sheng_jiang", "text": "中气升降失调（腹痛胀满/食后腹胀/二便失调）"}
        ]
      }
    ]
  },

  "step2_四维升降": {
    "description": "木火金水四象因中轴不转而失常。以下按左升右降分列。",
    "sections": [
      {
        "id": "HYY_B1_左路",
        "label": "二、左路（肝木升发 + 肾水温升）",
        "type": "checkbox",
        "items": [
          {"id": "hyy_zl_le_gan_yu", "text": "肝木郁结（胁痛/胸闷/头痛/烦躁/脉弦）"},
          {"id": "hyy_zl_le_gan_huo", "text": "肝火（头痛目赤/口干口苦/烦躁易怒/脉弦数）"},
          {"id": "hyy_zl_le_gan_feng", "text": "肝风内动（眩晕/头摇/肢麻/抽搐）"},
          {"id": "hyy_zl_le_shen_shui", "text": "肾水不温（腰膝酸冷/小便清长/四肢不温/脉沉细）"},
          {"id": "hyy_zl_le_yang_xu", "text": "肝阳虚（畏寒/四肢冷/沉闷懒言/小腹冷）"},
          {"id": "hyy_zl_le_gan_xue_xu", "text": "肝血虚（头晕眼花/肢体麻木/爪甲不荣/脉细）"}
        ]
      },
      {
        "id": "HYY_B2_右路",
        "label": "三、右路（肺金肃降 + 心火下济）",
        "type": "checkbox",
        "items": [
          {"id": "hyy_yl_fe_qi_ni", "text": "肺气逆（咳嗽/气喘/胸闷/鼻塞）"},
          {"id": "hyy_yl_fe_zao", "text": "肺燥（干咳无痰/咽干/鼻干/舌干）"},
          {"id": "hyy_yl_xin_huo", "text": "心火不降（心烦失眠/口舌生疮/心悸/舌红）"},
          {"id": "hyy_yl_xin_huo_shi", "text": "心火移热小肠（小便短赤/尿道灼热）"},
          {"id": "hyy_yl_wei_huo", "text": "胃火上逆（口臭/牙痛/消谷善饥/牙龈肿痛）"},
          {"id": "hyy_yl_fei_shui", "text": "肺气不降生水饮（咳喘/痰多清稀/胸闷）"}
        ]
      },
      {
        "id": "HYY_B3_中气不运派生",
        "label": "四、中气不运→四维不调的过渡症状",
        "type": "checkbox",
        "items": [
          {"id": "hyy_gd_sheng_bu_shang", "text": "清阳不升（头晕/清涕/疲倦/面色鲜白）"},
          {"id": "hyy_gd_jiu_bu_jiang", "text": "浊阴不降（腹满/便秘/嗳气/口臭）"},
          {"id": "hyy_gd_bu_tong", "text": "升降不通（上热下寒：口舌生疮+下肢冷）"},
          {"id": "hyy_gd_tan_shi", "text": "脾虚生湿（身重/纳呆/便溏/舌胖/苔腻）"}
        ]
      }
    ]
  },

  "step3_方药映射": {
    "description": "按黄元御经典方药组合——脾升胃降为纲",
    "sections": [
      {
        "id": "HYY_C1_方证",
        "label": "五、方药匹配",
        "type": "checkbox",
        "items": [
          {"id": "hyy_fz_xiang", "text": "脾虚湿盛 → 苓桂术甘汤"},
          {"id": "hyy_fz_gan_yu", "text": "肝郁气滞 → 四逆散"},
          {"id": "hyy_fz_wei_ni", "text": "胃气上逆 → 旋覆代赭汤"},
          {"id": "hyy_fz_fe_re", "text": "肺热咳喘 → 泻白散"},
          {"id": "hyy_fz_xin_jiao", "text": "心肾不交 → 黄连阿胶汤"},
          {"id": "hyy_fz_jie", "text": "解表（风寒束肺 → 麻黄汤/桂枝汤）"}
        ]
      }
    ]
  },

  "step4_知医邦量化": {
    "description": "脉诊和舌诊量化表",
