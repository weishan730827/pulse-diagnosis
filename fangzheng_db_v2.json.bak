      ]
    ],
    "类方": {
      "回阳升陷汤": {
        "组成": "生黄芪八钱 干姜六钱 当归身四钱 桂枝尖三钱 甘草一钱",
        "主治": "心肺阳虚，大气又下陷。心冷、背紧、恶寒，常觉短气",
        "脉象": "微弱而迟，右部兼沉",
        "注": "不含龙牡"
      },
      "理郁升陷汤": {
        "组成": "生黄芪六钱 知母三钱 当归身三钱 桂枝尖钱半 柴胡钱半 乳香三钱 没药三钱",
        "主治": "胸中大气下陷，又兼气分郁结，经络湮淤",
        "加减": "胁下撑胀或疼者，加龙骨、牡蛎各五钱",
        "龙牡用法": "敛戢肝火（以敛为泻），兼缩黄芪膨胀之力，非重镇潜降",
        "出处": "《参西录》理郁升陷汤条"
      },
      "醒脾升陷汤": {
        "组成": "生黄芪四钱 白术四钱 桑寄生三钱 川续断三钱 萸肉四钱 龙骨四钱 牡蛎四钱 川萆薢二钱 甘草二钱（蜜炙）",
        "主治": "脾气虚极下陷，小便不禁",
        "龙牡用法": "固涩小肠，收涩固脱，非重镇潜降",
        "出处": "《参西录》第684行"
      }
    },
    "来源": "张锡纯"
