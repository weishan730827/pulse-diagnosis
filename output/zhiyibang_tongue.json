{
  "_source": "知医邦AI中医舌诊量表（知医邦公众号2026年6月11日公开发布，初版）",
  "_version": "1.0",
  "_description": "舌诊维度量化数据结构，含舌面分区、舌体4维、舌苔3维、神态24项、舌下5项、辨证算法及36证素轮图。初版定性不定量，建议四诊合参。",

  "舌面分区": {
    "方法": "以轮廓环相似形内作10环",
    "分区定义": {
      "舌中": "4环线以内全部",
      "舌尖": "2环线~10环线之间中下片（时钟5点~7点60°）",
      "舌前": "4环线~8环线之间中下片（时钟4点~8点120°）",
      "舌侧": "7环线~9环线之间左右片（时钟1点~4点/8点~11点各90°）",
      "舌根": "4环线~8环线之间中上片（时钟10点~14点120°）"
    },
    "可用部位": ["全舌", "舌尖", "舌前", "舌中", "舌侧", "舌根"]
  },

  "维度定义": {
    "A_舌体": {
      "id": "A",
      "label": "舌体（舌质）",
      "description": "舌头的肌肉脉络组织",
      "子维度": {
        "舌体颜色": {
          "id": "A1",
          "options": {
            "AA": {"label": "浅淡发白", "分区症状": {"全舌": "偏亏", "舌尖": "心系亏", "舌前": "肺系亏", "舌中": "脾胃亏", "舌侧": "肝胆亏", "舌根": "肾系亏"}},
            "AB": {"label": "红艳", "分区症状": {"全舌": "偏热", "舌尖": "心系热", "舌前": "肺系热", "舌中": "脾胃热", "舌侧": "肝胆热", "舌根": "肾系热"}},
            "AC": {"label": "暗红", "分区症状": {"全舌": "虚热", "舌尖": "心系虚热", "舌前": "肺系虚热", "舌中": "脾胃虚热", "舌侧": "肝胆虚热", "舌根": "肾系虚热"}},
            "AD": {"label": "发紫", "分区症状": {"全舌": "偏滞", "舌尖": "心系滞", "舌前": "肺系滞", "舌中": "脾胃滞", "舌侧": "肝胆滞", "舌根": "肾系滞"}},
            "AE": {"label": "浅淡发青", "分区症状": {"全舌": "虚寒", "舌尖": "心系虚寒", "舌前": "肺系虚寒", "舌中": "脾胃虚寒", "舌侧": "肝胆虚寒", "舌根": "肾系虚寒"}}
          }
        },
        "裂纹": {
          "id": "A2",
          "options": {
            "AF": {"label": "舌面有裂纹", "适用部位": "全舌及各分区"}
          }
        },
        "点刺": {
          "id": "A3",
          "options": {
            "AG": {"label": "舌面有红点", "适用部位": "全舌及各分区"}
          }
        },
        "凹凸": {
          "id": "A4",
          "options": {
            "AH": {"label": "局部凹陷", "适用部位": ["舌尖", "舌前", "舌中", "舌侧", "舌根"], "分区症状": {"舌尖": "心系亏虚", "舌前": "肺系亏虚", "舌中": "脾胃亏虚", "舌侧": "肝胆亏虚", "舌根": "肾系亏虚"}},
            "AI": {"label": "局部凸起", "适用部位": ["舌尖", "舌前", "舌中", "舌侧", "舌根"], "分区症状": {"舌尖": "心系实滞", "舌前": "肺系实滞", "舌中": "脾胃实滞", "舌侧": "肝胆实滞", "舌根": "肾系实滞"}}
          }
        }
      }
    },

    "B_舌苔": {
      "id": "B",
      "label": "舌苔",
      "description": "舌面苔状物，由脱落的角化上皮、唾液、细菌、食物碎屑及渗出的白血细胞等组成",
      "子维度": {
        "舌苔颜色": {
          "id": "B1",
          "options": {
            "BA": {"label": "白色", "分区症状": {"全舌": "偏寒", "舌尖": "心系寒", "舌前": "肺系寒", "舌中": "脾胃寒", "舌侧": "肝胆寒", "舌根": "肾系寒"}},
            "BB": {"label": "黄色", "分区症状": {"全舌": "实热", "舌尖": "心系实热", "舌前": "肺系实热", "舌中": "脾胃实热", "舌侧": "肝胆实热", "舌根": "肾系实热"}},
            "BC": {"label": "灰色", "适用部位": "全舌及各分区"},
            "BD": {"label": "黑色", "适用部位": "全舌及各分区"}
          }
        },
        "舌苔形状": {
          "id": "B2",
          "options": {
            "BE": {"label": "苔厚，明显可见", "分区症状": {"全舌": "偏实", "舌尖": "心系实", "舌前": "肺系实", "舌中": "脾胃实", "舌侧": "肝胆实", "舌根": "肾系实"}},
            "BF": {"label": "苔少，难以辨识", "分区症状": {"全舌": "偏虚", "舌尖": "心系虚", "舌前": "肺系虚", "舌中": "脾胃虚", "舌侧": "肝胆虚", "舌根": "肾系虚"}},
            "BG": {"label": "无苔如牛肉", "适用部位": "全舌及各分区"}
          }
        },
        "舌苔质地": {
          "id": "B3",
          "options": {
            "BH": {"label": "湿滑、黏腻", "分区症状": {"全舌": "偏湿", "舌尖": "心系湿", "舌前": "肺系湿", "舌中": "脾胃湿", "舌侧": "肝胆湿", "舌根": "肾系湿"}},
            "BI": {"label": "干燥、粗糙", "分区症状": {"全舌": "偏燥", "舌尖": "心系燥", "舌前": "肺系燥", "舌中": "脾胃燥", "舌侧": "肝胆燥", "舌根": "肾系燥"}},
            "BJ": {"label": "光滑如镜面", "适用部位": "全舌及各分区"}
          }
        }
      }
    },

    "C_神态": {
      "id": "C",
      "label": "神态（舌头整体神色形态）",
      "description": "对辨证影响不大，可以不填",
      "options": {
        "CA": "舌色淡红不深不浅（舌淡红）",
        "CB": "舌苔薄薄一层自然分布均匀（苔薄）",
        "CC": "舌苔湿润不干燥不滑腻（苔润）",
        "CD": "舌头大而胖（舌胖）",
        "CE": "舌头小而瘦（舌瘦）",
        "CF": "舌头呈三角形（三角舌）",
        "CG": "舌尖开叉呈倒心形（桃心舌）",
        "CH": "舌头呈梨形像布袋子（布袋舌）",
        "CI": "舌头伸出很长呈条状（长条舌）",
        "CJ": "伸舌向一侧歪斜（歪斜舌）",
        "CK": "舌头短伸出困难（短缩舌）",
        "CL": "舌面有瘀紫色斑点（瘀点舌）",
        "CM": "舌头边上有齿痕（齿痕舌）",
        "CN": "舌苔整块剥脱（地图舌）",
        "CO": "苔如白粉堆积布满舌面（积粉苔）",
        "CP": "舌色淡偏胖细腻娇嫩（舌质嫩）",
        "CQ": "舌色暗皱缩粗糙苍老（舌质老）",
        "CR": "舌面两侧各挂一唾沫线（肝郁线）",
        "CS": "舌头肿（舌肿）",
        "CT": "舌头萎缩（舌萎）",
        "CU": "频吐舌头不自觉（弄舌）",
        "CV": "伸舌可见颤抖（舌颤）",
        "CW": "舌伸出口外不收（舌纵）",
        "CX": "舌卷缩不能伸出（舌卷）",
        "CY": "舌头僵硬（舌强）",
        "CZ": "舌头软弱无力（舌痿）"
      }
    },

    "D_舌下": {
      "id": "D",
      "label": "舌下（舌下静脉）",
      "description": "舌头下方与口腔底部相连的部位",
      "options": {
        "DA": {"label": "舌下两条静脉突起明显（舌脉怒张）"},
        "DB": {"label": "舌下两条静脉青紫（舌脉青紫）"},
        "DC": {"label": "舌下两条静脉乌紫（舌脉紫黯）"},
        "DD": {"label": "舌下见紫色斑点（舌下瘀斑）"},
        "DE": {"label": "舌下静脉细小色淡（舌脉浅淡）"}
      }
    }
  },

  "辨证算法": {
    "成立规则": {
      "整体成立": "同一选项（行）满足3个分区即整体成立",
      "分区成立": "同一分区（列）满足4个选项即分区成立"
    },
    "基础证型推导": {
      "表证": "AB ∩ BA",
      "胃证": "BB",
      "胆证": "AC",
      "肝证": "AE",
      "心证": "AB",
      "脾证": "BC",
      "肺证": "BA",
      "肾证": "AD",
      "寒证": "AE ∪ BA",
      "热证": "AB ∪ AC ∪ AG ∪ BB",
      "虚证": "AC ∪ AE ∪ AH ∪ BF ∪ CM",
      "实证": "AI ∪ BB ∪ BE",
      "燥证": "AF ∪ BI ∪ CE",
      "湿证": "BH ∪ CD ∪ CM",
      "亏证": "AA ∪ AF ∪ AH ∪ DE",
      "滞证": "AD ∪ AI ∪ CL ∪ DA ∪ DB ∪ DC ∪ DD",
      "虚寒": "AE",
      "虚热": "AC",
      "实寒": "AA ∩ BA",
      "实热": "BB",
      "津亏": "AC ∩ BI",
      "水泛": "AE ∩ BH",
      "痰滞": "BA ∩ BE",
      "燥结": "BB ∩ BE"
    }
  },

  "证素推算轮图": {
    "_说明": "基于基础证型组合推导36证素，参见知医邦AI中医证素推算轮图",
    "36证素": [
      "寒证", "热证", "虚寒", "实寒", "虚热", "实热",
      "阳盛", "阳虚", "阴盛", "阴虚",
      "寒湿", "湿热", "凉燥", "燥热",
      "虚证", "实证", "气虚", "血虚", "气滞", "血瘀",
      "亏证", "滞证", "燥证", "湿证",
      "水泛", "湿滞", "燥结", "津亏",
      "厥证", "郁证", "痰证", "枯证",
      "闭证", "积证", "劳证", "脱证"
    ]
  },

  "舌诊三字经": {
    "_说明": "顺口溜，供参考，非算法部分",
    "口诀": [
      "舌色青，肝不好；舌色紫，肾不好；舌色绛，心不好",
      "舌色红，胆不好；舌色白，肺不好；舌色黄，胃不好；舌色灰，脾不好",
      "舌尖红，常失眠；舌边红，多烦躁",
      "舌尖凹，多健忘；舌前凹，易感冒；舌中凹，常拉稀；舌根凹，夜尿多；舌边凹，胆子小",
      "舌尖凸，头会痛；舌前凸，胸会堵；舌中凸，常胀气；舌边凸，易生气；舌根凸，多痔疮",
      "舌下紫，循环差；舌红紫，心肺差；舌淡白，是贫血",
      "舌头肿，是水肿；舌头干，是脱水；舌色黑，是高热；舌深红，感染急",
      "苔白厚，感染起；苔色黄，感染重；芒刺舌，必发热；瘀斑舌，有瘀血",
      "草莓舌，猩红热；裂纹舌，缺滋养；牛肉舌，缺叶酸；镜面舌，是舌炎；黑毛舌，多真菌",
      "桃心舌，系带短；布袋舌，腰腿痛；三角舌，脾气爆",
      "齿痕舌，湿气重；瘦薄舌，身子弱；瘦长舌，慢性病；长条舌，眼昏花；勺子舌，心慌乱",
      "歪斜舌，要中风；肿胀舌，见过敏",
      "霉酱苔，多宿食；花剥苔，寄生虫；积粉苔，有疫情"
    ]
  },

  "_与脉诊量表的异同": {
    "相同": "均为知医邦公开发布的AI中医量表，结构为维度→选项→算法→结论",
    "不同": [
      "舌诊为初版（v1.0），脉诊为成熟版（已在公众号和中国产业经济信息网发布）",
      "舌诊无置信度公式（定性不定量），脉诊有完整∈公式（定量）",
      "舌诊选项为并列表（可多选可不选），脉诊为单维度单选",
      "舌诊包含证素轮图推导36证素，脉诊仅28脉",
      "舌诊无分部适配规则（分区算法已内置），脉诊有分部适配说明"
    ]
  }
}
