{
  "_name": "张锡纯脉诊辨证勾选表",
  "_version": "恢复版",
  "_source": "张锡纯《医学衷中参西录》172医案脉象原文",
  "_method": "左右手三部总按 + 分部多选 → 医案脉象签名反向匹配 → 命中医案+方剂",
  "_principle": "所有脉象选项均提取自原著医案原文，每个匹配结果可追溯到具体案号",

  "step1_总按": {
    "description": "搭双手总按，判整体脉象特征",
    "sections": [
      {
        "id": "zxc_depth",
        "label": "浮沉（深度）",
        "type": "checkbox",
        "items": [
          {"id": "zxc_fu", "text": "浮（轻取即得）"},
          {"id": "zxc_chen", "text": "沉（重按始得）"},
          {"id": "zxc_fu2", "text": "伏（推筋着骨始得）"}
        ]
      },
      {
        "id": "zxc_speed",
        "label": "迟数（速度）",
        "type": "checkbox",
        "items": [
          {"id": "zxc_chi", "text": "迟（一息不足四至）"},
          {"id": "zxc_shu", "text": "数（一息五至以上）"},
          {"id": "zxc_huan", "text": "缓（从容和缓）"},
          {"id": "zxc_ji", "text": "疾（一息七至以上）"}
        ]
      },
      {
        "id": "zxc_strength",
        "label": "虚实（力度）",
        "type": "checkbox",
        "items": [
          {"id": "zxc_youli", "text": "有力"},
          {"id": "zxc_wuli", "text": "无力"},
          {"id": "zxc_xu", "text": "虚（按之空虚）"},
          {"id": "zxc_shi", "text": "实（应指有力）"}
        ]
      }
    ]
  },

  "step2_左右对比": {
    "description": "双手同取对比",
    "sections": [
      {
        "id": "zxc_lr_compare",
        "label": "左右手对比",
        "type": "radio",
        "items": [
          {"id": "zxc_lr_left_strong", "text": "左手偏强"},
          {"id": "zxc_lr_right_strong", "text": "右手偏强"},
          {"id": "zxc_lr_equal", "text": "左右持平"},
          {"id": "zxc_lr_left_weak", "text": "左手偏弱"},
          {"id": "zxc_lr_right_weak", "text": "右手偏弱"}
        ]
      }
    ]
  },

