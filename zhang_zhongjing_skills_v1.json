  {
    "id": "SKILL_ZZJ_001",
    "group": "太阳病·伤寒",
    "formula": "麻黄汤",
    "case_count": 5,
    "trigger": {
      "主症": [
        "恶寒发热",
        "无汗",
        "头项强痛",
        "身疼腰痛",
        "骨节疼痛",
        "喘"
      ],
      "脉象_总体": [
        "浮紧"
      ],
      "六经": "太阳病"
    },
    "core_logic": "原文第35条：'太阳病，头痛发热，身疼腰痛，骨节疼痛，恶风无汗而喘者，麻黄汤主之。'麻黄发汗解表为君，桂枝助麻黄解肌，杏仁降肺平喘，甘草调和。此为太阳伤寒表实证正治。",
    "base": "麻黄9g 桂枝6g 杏仁9g 甘草3g",
    "if_then": [
      {
        "if": "太阳阳明合病下利",
        "then": "加葛根12g→葛根汤"
      },
      {
        "if": "太阳阳明合病不下利但呕",
        "then": "加葛根12g、半夏9g→葛根加半夏汤"
      },
      {
        "if": "外寒内热烦躁",
        "then": "加石膏30g→大青龙汤"
      },
      {
        "if": "心下有水气",
        "then": "去杏仁加干姜/细辛/半夏→小青龙汤"
      }
    ],
    "note": "张仲景原文为根本。太阳病提纲：脉浮，头项强痛而恶寒。麻黄汤证=脉浮紧+无汗+身痛。禁用于咽喉干燥者、淋家、疮家、亡血家等。"
  },
  {
