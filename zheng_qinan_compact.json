        },
        {
          "signs": [
            "二便不利",
            "小便短赤",
            "大便秘结"
          ],
          "diagnosis": "阴虚"
        }
      ]
    },
    {
      "step": 3,
      "name": "辨舌脉",
      "key": "舌象+脉象",
      "rules": [
