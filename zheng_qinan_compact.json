  "treatment_principles": {
    "阳虚": "温阳固本——四逆汤/理中汤/真武汤 为主",
    "阴虚": "养阴清热——黄连阿胶汤/白虎汤/承气汤 为主"
  },
  "core_rules": [
    {
      "id": "zqa_01",
      "category": "阴阳总纲",
      "rule": "辨证首分阴阳，万病不出阴阳二字"
    },
    {
      "id": "zqa_02",
      "category": "阳虚辨识",
      "rule": ""
    },
    {
      "id": "zqa_03",
      "category": "阴虚辨识",
      "rule": ""
    },
    {
      "id": "zqa_04",
      "category": "阳虚阴盛核心病机",
      "rule": "阳虚为本，阴盛为标；阳不化阴则湿浊内生、水饮停聚、瘀血凝结"
    },
    {
      "id": "zqa_05",
      "category": "真阳判别法",
      "rule": "辨阳虚之关键不在热象有无，而在阳气虚损的本质：身重恶寒、目瞑嗜卧、声低息短、少气懒言、渴喜热饮。火症为假热，阳虚为真寒。"
    },
    {
      "id": "zqa_06",
      "category": "气有余便是火",
      "rule": "阳气虚损则寒从中生；阳气亢盛则火从内生。脚气、手癣、足癣等为阳气不足、阴湿外溢之候，非实火。"
    },
    {
      "id": "zqa_07",
      "category": "用药大纲",
      "rule": "扶阳以附子为首，干姜佐之；寒湿重者加白术、茯苓；气陷者加黄芪；血虚者加当归。"
    },
    {
      "id": "zqa_08",
      "category": "阳虚禁忌",
      "rule": "阳虚证禁用寒凉攻伐之品，当以温补为主。发散药、攻下药、清热药皆损阳气，须审慎。"
    },
    {
      "id": "zqa_09",
      "category": "阴盛通阳外越",
      "rule": "此为真寒假热，治当峻补元阳，禁用清热。与阴虚阳亢之真热烦渴截然不同，鉴别点：舌润与否、渴饮冷热、脉有力与否。"
    },
    {
      "id": "zqa_10",
      "category": "舌诊辨阴阳",
      "rule": "舌质淡而润为阳虚；舌质红而干为阴虚。本案舌淡粉、水滑苔白→阳虚明证。"
    },
    {
