  "step2_太阳变证": {
    "description": "太阳病误治或自然传变产生的变证",
    "items": [
      {"id": "zzj_bz_fanzao", "text": "【变证】烦躁 + 不汗出 → 大青龙汤"},
      {"id": "zzj_bz_chuan", "text": "【变证】喘 + 汗出 + 无大热 → 麻杏石甘汤"},
      {"id": "zzj_bz_xinshui", "text": "【蓄水】小便不利 + 渴 + 水入即吐 → 五苓散"},
      {"id": "zzj_bz_xuxue", "text": "【蓄血】少腹硬满 + 其人如狂 → 桃核承气汤/抵当汤"},
      {"id": "zzj_bz_jiexiong", "text": "【结胸】心下痛 + 按之石硬 → 大陷胸汤"},
      {"id": "zzj_bz_pi", "text": "【痞证】心下痞 + 按之濡 → 泻心汤类"},
      {"id": "zzj_bz_quexin", "text": "【缺心阳】心下悸 + 叉手自冒心 → 桂枝甘草汤"},
      {"id": "zzj_bz_benrun", "text": "【奔豚】气从少腹上冲心 → 桂枝加桂汤/茯苓桂枝甘草大枣汤"}
    ]
  },

